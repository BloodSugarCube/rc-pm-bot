APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=rc_pm_bot
DB_USERNAME=root
DB_PASSWORD=

# DB_CONNECTION=sqlite
# DB_DATABASE=database/database.sqlite

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
# Over HTTPS in production set SESSION_SECURE_COOKIE=true (and trust the reverse proxy if used).
SESSION_SECURE_COOKIE=

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# Rocket.Chat bot (см. config/bot.php)
ROCKETCHAT_URL=https://chat.example.com
ROCKETCHAT_BOT_USERNAME=bot_ai
ROCKETCHAT_BOT_PASSWORD=
# Опционально вместо пароля: User ID + Personal Access Token (профиль → Security → Personal Access Tokens)
ROCKETCHAT_USER_ID=
ROCKETCHAT_AUTH_TOKEN=

# Админ-панель /admin
BOT_ADMIN_USERNAME=admin
BOT_ADMIN_PASSWORD=

BOT_TIMEZONE=Europe/Moscow
BOT_MORNING_POLL_TEXT="@all Что в работе?"
BOT_DAY_POLL_TEXT="Что в работе?"
